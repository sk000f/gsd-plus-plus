{
  "workflow": {
    "code_review": true,
    "generate_docs": true,
    "review_max_cycles": 2
  },
  "review": {
    "block_on_critical": true,
    "enforce_claude_md": true
  },
  "documentation": {
    "output_dir": "docs",
    "api_spec_format": "yaml",
    "adr_dir": "docs/adr",
    "auto_update_readme": true,
    "doc_types": ["api", "technical", "adr", "readme"]
  }
}
